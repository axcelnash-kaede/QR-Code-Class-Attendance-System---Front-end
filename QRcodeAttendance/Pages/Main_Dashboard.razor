@page "/main_dashboard"
@using MudBlazor
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using QRcodeAttendance.Services
@inject NavigationManager nav
@inject IJSRuntime JS
@inject HttpClient http
@inject ISnackbar Snackbar

<div class="dashboard-wrapper">

    <div class="dashboard-container">

        <div class="sidebar">

            <div class="sidebar-header">
                <img src="/aclc.png" class="sidebar-logo-img" />
                <div class="sidebar-title">QR Classroom Attendance</div>
            </div>

            <div class="sidebar-content">
                <div class="section-title">Sections</div>

                @if (isLoadingSections)
                {
                    <div class="sidebar-empty-state">
                        Loading sections...
                    </div>
                }
                else if (!sections.Any())
                {
                    <div class="sidebar-empty-state">
                        No sections or subjects found for this teacher.
                    </div>
                }
                else
                {
                    <MudExpansionPanels Elevation="0">
                        @foreach (var sec in sections)
                        {
                            <MudExpansionPanel Text="@sec.SectionName">

                                @foreach (var subject in sec.Subjects)
                                {
                                    <MudButton FullWidth="true"
                                               Class="subject-btn"
                                               OnClick="@(async () => await SelectSectionAndSubjectAsync(sec, subject))">
                                        @subject.SubjectName
                                    </MudButton>
                                }

                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                }
            </div>

            <MudButton Variant="Variant.Filled"
                       Class="logout-btn"
                       OnClick="HandleLogout">
                Log Out
            </MudButton>

        </div>

        <div class="main-panel">

            <div class="summary-grid">
                <div class="summary-card">
                    <div class="summary-label">Total Students</div>
                    <div class="summary-value">@TeacherStats.TotalStudents</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Total Sessions</div>
                    <div class="summary-value">@TeacherStats.TotalSessions</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Active Sessions</div>
                    <div class="summary-value">@TeacherStats.ActiveSessions</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Closed Sessions</div>
                    <div class="summary-value">@TeacherStats.ClosedSessions</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(sessionMessage))
            {
                <MudAlert Severity="@sessionMessageSeverity"
                          Variant="Variant.Filled"
                          Dense="true"
                          Style="margin-bottom: 14px;">
                    @sessionMessage
                </MudAlert>
            }

            @if (HasActiveSession)
            {
                <MudAlert Severity="Severity.Info"
                          Variant="Variant.Outlined"
                          Dense="true"
                          Style="margin-bottom: 14px;">
                    Active session ready for mobile scan:
                    <b>@activeSessionSectionName • @activeSessionSubjectName</b>
                    — Session #@generatedSessionId
                </MudAlert>
            }

            <div class="top-bar">
                <div class="title">
                    @(string.IsNullOrEmpty(selectedSectionName)
                                        ? "Select a Section"
                                        : $"{selectedSectionName} • {selectedSubjectName}")
                </div>

                <div class="action-bar">
                    <MudButton Class="qr-btn"
                               Disabled="@(!CanGenerateQr || isGeneratingQr || HasActiveSession)"
                               OnClick="GenerateQrAsync">
                        @(isGeneratingQr ? "Generating..." : "Generate QR")
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Disabled="@(!HasActiveSession)"
                               OnClick="OpenQrModal">
                        View QR
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Disabled="@(!HasActiveSession || isClosingSession)"
                               OnClick="CloseSessionAsync">
                        @(isClosingSession ? "Closing..." : "Close Session")
                    </MudButton>

                    <MudButton Class="pdf-btn">Print PDF</MudButton>
                </div>
            </div>

            <div class="table-card">
                @if (isLoadingAttendance)
                {
                    <div class="empty-state">
                        Loading attendance records...
                    </div>
                }
                else if (attendanceList.Any())
                {
                    <div class="table-toolbar">
                        <div class="table-subtitle">
                            Showing attendance records for <b>@selectedSectionName</b> - <b>@selectedSubjectName</b>
                        </div>
                    </div>

                    <MudTable T="Attendance"
                              Items="@attendanceList"
                              Dense="true"
                              FixedHeader="true"
                              Height="100%"
                              Bordered="true"
                              Striped="true">

                        <HeaderContent>
                            <MudTh>Student ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Time</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="row">
                            <MudTd DataLabel="Student ID">@row.StudentId</MudTd>
                            <MudTd DataLabel="Name">@row.Name</MudTd>
                            <MudTd DataLabel="Status">
                                <span class="status-chip @GetStatusClass(row.Status)">
                                    @row.Status
                                </span>
                            </MudTd>
                            <MudTd DataLabel="Time">@row.Time</MudTd>
                        </RowTemplate>

                    </MudTable>
                }
                else
                {
                    <div class="empty-state">
                        No attendance records found for this section and subject.
                    </div>
                }
            </div>

        </div>

    </div>

</div>

@if (showQrModal)
{
    <div class="qr-modal-backdrop" @onclick="CloseQrModal">
        <div class="qr-modal-card" @onclick:stopPropagation="true">
            <div class="qr-modal-header">
                <div>
                    <div class="qr-modal-title">Active QR Session</div>
                    <div class="qr-modal-subtitle">@activeSessionSectionName - @activeSessionSubjectName</div>
                </div>

                <MudButton Variant="Variant.Text" OnClick="CloseQrModal">Close</MudButton>
            </div>

            <div class="qr-modal-body">
                @if (!string.IsNullOrWhiteSpace(generatedQrCode))
                {
                    <img class="generated-qr-image"
                         src="@GetQrImageSource()"
                         alt="Generated QR Code" />
                }

                <div class="qr-session-meta">
                    <div><b>Session ID:</b> @generatedSessionId</div>
                    <div><b>Status:</b> @(HasActiveSession ? "Active" : "Closed")</div>
                    <div><b>Expiry:</b> 30 minutes</div>
                </div>

                <div style="width:100%; display:flex; justify-content:flex-end; gap:10px; margin-top:8px;">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               OnClick="CloseQrModal">
                        Done
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Disabled="@(!HasActiveSession || isClosingSession)"
                               OnClick="CloseSessionAsync">
                        @(isClosingSession ? "Closing..." : "Close Session")
                    </MudButton>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isGeneratingQr = false;
    private bool isClosingSession = false;
    private bool showQrModal = false;
    private bool isLoadingSections = false;
    private bool isLoadingAttendance = false;

    private int? selectedSectionId;
    private int? selectedSubjectId;
    private string selectedSectionName = "";
    private string selectedSubjectName = "";

    private string generatedQrCode = "";
    private int generatedSessionId;
    private string activeSessionSectionName = "";
    private string activeSessionSubjectName = "";

    private string sessionMessage = "";
    private Severity sessionMessageSeverity = Severity.Info;

    private bool HasActiveSession => generatedSessionId > 0 && !string.IsNullOrWhiteSpace(generatedQrCode);

    public class TeacherSectionSubjectItemDto
    {
        public int SubjectId { get; set; }
        public string SubjectName { get; set; } = string.Empty;
    }

    public class TeacherSectionSubjectsDto
    {
        public int SectionId { get; set; }
        public string SectionName { get; set; } = string.Empty;
        public List<TeacherSectionSubjectItemDto> Subjects { get; set; } = new();
    }

    public class Attendance
    {
        public string StudentId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string Time { get; set; } = string.Empty;
    }

    public class TeacherDashboardResponse
    {
        public int TotalSessions { get; set; }
        public int ActiveSessions { get; set; }
        public int ClosedSessions { get; set; }
        public int TotalAttendanceRecords { get; set; }
        public int TotalStudents { get; set; }
    }

    public class CreateSessionRequest
    {
        public string? Title { get; set; }
        public int SubjectId { get; set; }
        public int SectionId { get; set; }
        public int? GraceMinutes { get; set; }
        public int? ExpirationMinutes { get; set; }
    }

    public class CreateSessionResponse
    {
        public int SessionId { get; set; }
        public string? QrCode { get; set; }
        public string? Message { get; set; }
    }

    public class CloseSessionResponse
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
    }

    private TeacherDashboardResponse TeacherStats { get; set; } = new();
    private List<TeacherSectionSubjectsDto> sections = new();
    private List<Attendance> attendanceList = new();

    private bool CanGenerateQr => selectedSectionId.HasValue && selectedSubjectId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomCenter;
        Snackbar.Configuration.PreventDuplicates = true;
        Snackbar.Configuration.NewestOnTop = true;
        Snackbar.Configuration.ShowCloseIcon = true;

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (string.IsNullOrWhiteSpace(token))
        {
            nav.NavigateTo("/login");
            return;
        }

        await LoadTeacherDashboardAsync(token);
        await LoadTeacherSectionSubjectsAsync(token);
    }

    private async Task SelectSectionAndSubjectAsync(TeacherSectionSubjectsDto section, TeacherSectionSubjectItemDto subject)
    {
        selectedSectionId = section.SectionId;
        selectedSectionName = section.SectionName;

        selectedSubjectId = subject.SubjectId;
        selectedSubjectName = subject.SubjectName;

        sessionMessage = "";
        await LoadAttendanceFromApiAsync();
    }

    private async Task LoadTeacherDashboardAsync(string token)
    {
        try
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var result = await http.GetFromJsonAsync<TeacherDashboardResponse>(
                $"{ApiConfig.BaseUrl}/api/Dashboard/teacher"
            );

            if (result != null)
                TeacherStats = result;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load dashboard data: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadTeacherSectionSubjectsAsync(string token)
    {
        try
        {
            isLoadingSections = true;
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var result = await http.GetFromJsonAsync<List<TeacherSectionSubjectsDto>>(
                $"{ApiConfig.BaseUrl}/api/attendance/teacher-sections-subjects"
            );

            sections = result ?? new List<TeacherSectionSubjectsDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load sections and subjects: {ex.Message}", Severity.Error);
            sections = new List<TeacherSectionSubjectsDto>();
        }
        finally
        {
            isLoadingSections = false;
        }
    }

    private async Task LoadAttendanceFromApiAsync()
    {
        if (!selectedSectionId.HasValue || !selectedSubjectId.HasValue)
        {
            attendanceList = new List<Attendance>();
            return;
        }

        try
        {
            isLoadingAttendance = true;

            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if (string.IsNullOrWhiteSpace(token))
            {
                nav.NavigateTo("/login");
                return;
            }

            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var result = await http.GetFromJsonAsync<List<Attendance>>(
                $"{ApiConfig.BaseUrl}/api/attendance/by-section-subject?sectionId={selectedSectionId.Value}&subjectId={selectedSubjectId.Value}"
            );

            attendanceList = result ?? new List<Attendance>();
        }
        catch (Exception ex)
        {
            attendanceList = new List<Attendance>();
            Snackbar.Add($"Failed to load attendance records: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoadingAttendance = false;
        }
    }

    private async Task GenerateQrAsync()
    {
        if (!selectedSectionId.HasValue || !selectedSubjectId.HasValue)
        {
            sessionMessage = "Select a section and subject first.";
            sessionMessageSeverity = Severity.Warning;
            Snackbar.Add(sessionMessage, Severity.Warning);
            return;
        }

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (string.IsNullOrWhiteSpace(token))
        {
            sessionMessage = "You are not logged in.";
            sessionMessageSeverity = Severity.Error;
            Snackbar.Add(sessionMessage, Severity.Error);
            nav.NavigateTo("/login");
            return;
        }

        isGeneratingQr = true;

        try
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var payload = new CreateSessionRequest
            {
                Title = $"{selectedSectionName} - {selectedSubjectName}",
                SubjectId = selectedSubjectId.Value,
                SectionId = selectedSectionId.Value,
                GraceMinutes = 5,
                ExpirationMinutes = 30
            };

            var response = await http.PostAsJsonAsync(
                $"{ApiConfig.BaseUrl}/api/attendance/create-session",
                payload
            );

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CreateSessionResponse>();

                if (result != null && result.SessionId > 0 && !string.IsNullOrWhiteSpace(result.QrCode))
                {
                    generatedSessionId = result.SessionId;
                    generatedQrCode = (result.QrCode ?? "").Trim();
                    activeSessionSectionName = selectedSectionName;
                    activeSessionSubjectName = selectedSubjectName;
                    showQrModal = true;

                    sessionMessage = string.IsNullOrWhiteSpace(result.Message)
                        ? "Session created successfully. QR code ready."
                        : $"{result.Message} QR code ready.";

                    sessionMessageSeverity = Severity.Success;
                    Snackbar.Add(sessionMessage, Severity.Success);

                    await LoadTeacherDashboardAsync(token);
                    await LoadAttendanceFromApiAsync();
                }
                else
                {
                    sessionMessage = "Session created but no QR data was returned.";
                    sessionMessageSeverity = Severity.Warning;
                    Snackbar.Add(sessionMessage, Severity.Warning);
                }
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                sessionMessage = string.IsNullOrWhiteSpace(errorText)
                    ? "Failed to create QR session."
                    : errorText;
                sessionMessageSeverity = Severity.Error;
                Snackbar.Add(sessionMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            sessionMessage = $"QR generation failed: {ex.Message}";
            sessionMessageSeverity = Severity.Error;
            Snackbar.Add(sessionMessage, Severity.Error);
        }
        finally
        {
            isGeneratingQr = false;
        }
    }

    private async Task CloseSessionAsync()
    {
        if (!HasActiveSession)
        {
            sessionMessage = "There is no active session to close.";
            sessionMessageSeverity = Severity.Warning;
            Snackbar.Add(sessionMessage, Severity.Warning);
            return;
        }

        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (string.IsNullOrWhiteSpace(token))
        {
            sessionMessage = "You are not logged in.";
            sessionMessageSeverity = Severity.Error;
            Snackbar.Add(sessionMessage, Severity.Error);
            nav.NavigateTo("/login");
            return;
        }

        isClosingSession = true;

        try
        {
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var response = await http.PostAsync(
                $"{ApiConfig.BaseUrl}/api/attendance/close?sessionId={generatedSessionId}",
                null
            );

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CloseSessionResponse>();

                sessionMessage = string.IsNullOrWhiteSpace(result?.Message)
                    ? "Session closed successfully."
                    : result!.Message!;

                sessionMessageSeverity = Severity.Success;
                Snackbar.Add(sessionMessage, Severity.Success);

                generatedSessionId = 0;
                generatedQrCode = "";
                activeSessionSectionName = "";
                activeSessionSubjectName = "";
                showQrModal = false;

                await LoadTeacherDashboardAsync(token);
                await LoadAttendanceFromApiAsync();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                sessionMessage = string.IsNullOrWhiteSpace(errorText)
                    ? "Failed to close session."
                    : errorText;
                sessionMessageSeverity = Severity.Error;
                Snackbar.Add(sessionMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            sessionMessage = $"Failed to close session: {ex.Message}";
            sessionMessageSeverity = Severity.Error;
            Snackbar.Add(sessionMessage, Severity.Error);
        }
        finally
        {
            isClosingSession = false;
        }
    }

    private void OpenQrModal()
    {
        if (HasActiveSession)
            showQrModal = true;
    }

    private string GetQrImageSource()
    {
        if (string.IsNullOrWhiteSpace(generatedQrCode))
            return string.Empty;

        if (generatedQrCode.StartsWith("data:image", StringComparison.OrdinalIgnoreCase))
            return generatedQrCode;

        return $"data:image/png;base64,{generatedQrCode}";
    }

    private void CloseQrModal()
    {
        showQrModal = false;
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Present" => "status-present",
            "Late" => "status-late",
            "Absent" => "status-absent",
            _ => ""
        };
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "userEmail");
        nav.NavigateTo("/login", true);
    }
}