@page "/main_dashboard"
@using MudBlazor
@inject NavigationManager nav
@inject IJSRuntime JS

<div class="dashboard-wrapper">

    <div class="dashboard-container">

        <div class="sidebar">

            <div class="sidebar-header">
                <div class="sidebar-title">QR Classroom Attendance</div>
            </div>

            <div class="sidebar-content">
                <div class="section-title">Sections</div>

                <MudExpansionPanels Elevation="0">
                    @foreach (var sec in sections)
                    {
                        <MudExpansionPanel Text="@sec.Name">

                            @foreach (var subject in sec.Subjects)
                            {
                                <MudButton FullWidth="true"
                                           Class="subject-btn"
                                           OnClick="@(() => LoadAttendance(sec.Name, subject))">
                                    @subject
                                </MudButton>
                            }

                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Class="logout-btn"
                       OnClick="HandleLogout">
                Log Out
            </MudButton>

        </div>

        <div class="main-panel">

            <div class="summary-grid">
                <div class="summary-card">
                    <div class="summary-label">Total Students</div>
                    <div class="summary-value">@TotalStudents</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Present</div>
                    <div class="summary-value">@PresentCount</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Late</div>
                    <div class="summary-value">@LateCount</div>
                </div>

                <div class="summary-card">
                    <div class="summary-label">Absent</div>
                    <div class="summary-value">@AbsentCount</div>
                </div>
            </div>

            <div class="top-bar">
                <div class="title">
                    @(string.IsNullOrEmpty(selectedSection)
                                        ? "Select a Section"
                                        : $"{selectedSection} - {selectedSubject}")
                </div>

                <div class="action-bar">
                    <MudButton Class="qr-btn">Generate QR</MudButton>
                    <MudButton Class="pdf-btn">Print PDF</MudButton>
                </div>
            </div>

            <div class="table-card">
                @if (attendanceList.Any())
                {
                    <div class="table-toolbar">
                        <div class="table-subtitle">
                            Showing attendance records for <b>@selectedSection</b> - <b>@selectedSubject</b>
                        </div>
                    </div>

                    <MudTable T="Attendance"
                              Items="@attendanceList"
                              Dense="true"
                              FixedHeader="true"
                              Height="100%"
                              Bordered="true"
                              Striped="true">

                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Time</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="row">
                            <MudTd DataLabel="ID">@row.ID</MudTd>
                            <MudTd DataLabel="Name">@row.Name</MudTd>
                            <MudTd DataLabel="Status">
                                <span class="status-chip @GetStatusClass(row.Status)">
                                    @row.Status
                                </span>
                            </MudTd>
                            <MudTd DataLabel="Time">@row.Time</MudTd>
                        </RowTemplate>

                    </MudTable>
                }
                else
                {
                    <div class="empty-state">
                        Select a section and subject from the sidebar to view attendance records.
                    </div>
                }
            </div>

        </div>

    </div>

</div>

@code {
    private string selectedSection = "";
    private string selectedSubject = "";

    public class Section
    {
        public string Name { get; set; }
        public List<string> Subjects { get; set; }
    }

    public class Attendance
    {
        public string ID { get; set; }
        public string Name { get; set; }
        public string Status { get; set; }
        public string Time { get; set; }
    }

    private List<Section> sections = new()
    {
        new Section
        {
            Name = "BSIT-22F",
            Subjects = new List<string> { "PE", "Math" }
        },
        new Section
        {
            Name = "BSIT-22C",
            Subjects = new List<string> { "Database", "Networking" }
        }
    };

    private List<Attendance> attendanceList = new();

    private int TotalStudents => attendanceList.Count;
    private int PresentCount => attendanceList.Count(x => x.Status == "Present");
    private int LateCount => attendanceList.Count(x => x.Status == "Late");
    private int AbsentCount => attendanceList.Count(x => x.Status == "Absent");

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (string.IsNullOrWhiteSpace(token))
        {
            nav.NavigateTo("/login");
        }
    }

    private void LoadAttendance(string section, string subject)
    {
        selectedSection = section;
        selectedSubject = subject;

        attendanceList = new List<Attendance>
        {
            new Attendance { ID = "2024-001", Name = "Juan Dela Cruz", Status = "Present", Time = "8:01 AM" },
            new Attendance { ID = "2024-002", Name = "Maria Santos", Status = "Late", Time = "8:15 AM" },
            new Attendance { ID = "2024-003", Name = "Carlo Reyes", Status = "Absent", Time = "-" },
            new Attendance { ID = "2024-004", Name = "Angela Cruz", Status = "Present", Time = "7:58 AM" }
        };
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Present" => "status-present",
            "Late" => "status-late",
            "Absent" => "status-absent",
            _ => ""
        };
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "userEmail");
        nav.NavigateTo("/login", true);
    }
}