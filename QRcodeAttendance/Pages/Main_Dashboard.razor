@page "/main_dashboard"
@using MudBlazor

<div class="dashboard-wrapper">

    <div class="dashboard-container">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <div class="sidebar-header">
                <img src="aclc.png" class="sidebar-logo-img" />
                <div class="sidebar-title">QR Classroom</div>
            </div>

            <div class="sidebar-content">
                <div class="section-title">Sections</div>

                <MudExpansionPanels Elevation="0">
                    @foreach (var sec in sections)
                    {
                        <MudExpansionPanel Text="@sec.Name">

                            @foreach (var subject in sec.Subjects)
                            {
                                <MudButton FullWidth="true"
                                           Class="subject-btn"
                                           OnClick="@(() => LoadAttendance(sec.Name, subject))">
                                    @subject
                                </MudButton>
                            }

                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Class="logout-btn"
                       OnClick="HandleLogout">
                Log Out
            </MudButton>

        </div>

        <!-- MAIN CONTENT -->
        <div class="main-panel">

            <!-- TOP BAR -->
            <div class="top-bar">
                <div class="title">
                    @(string.IsNullOrEmpty(selectedSection)
                                        ? "Select a Section"
                                        : $"{selectedSection} - {selectedSubject}")
                </div>

                <div class="action-bar">
                    <MudButton Class="qr-btn">Generate QR</MudButton>
                    <MudButton Class="pdf-btn">Print PDF</MudButton>
                </div>
            </div>

            <!-- TABLE CARD -->
            <div class="table-card">

                <MudTable T="Attendance"
                          Items="@attendanceList"
                          Dense="true"
                          FixedHeader="true"
                          Height="100%"
                          Bordered="true"
                          Striped="true">

                    <HeaderContent>
                        <MudTh Style="width:33%">ID</MudTh>
                        <MudTh Style="width:33%">Name</MudTh>
                        <MudTh Style="width:33%">Time</MudTh>
                    </HeaderContent>

                    <RowTemplate Context="row">
                        <MudTd DataLabel="ID">@row.ID</MudTd>
                        <MudTd DataLabel="Name">@row.Name</MudTd>
                        <MudTd DataLabel="Time">@row.Time</MudTd>
                    </RowTemplate>

                </MudTable>

            </div>

        </div>

    </div>

</div>

@code {
    string selectedSection = "";
    string selectedSubject = "";

    public class Section
    {
        public string Name { get; set; }
        public List<string> Subjects { get; set; }
    }

    public class Attendance
    {
        public string ID { get; set; }
        public string Name { get; set; }
        public string Status { get; set; }
        public string Time { get; set; }
    }

    List<Section> sections = new()
    {
        new Section
        {
            Name = "BSIT 1A",
            Subjects = new List<string> { "Programming", "Math" }
        },
        new Section
        {
            Name = "BSIT 2B",
            Subjects = new List<string> { "Database", "Networking" }
        }
    };

    List<Attendance> attendanceList = new();

    void LoadAttendance(string section, string subject)
    {
        selectedSection = section;
        selectedSubject = subject;

        attendanceList = new List<Attendance>
    {
        new Attendance { Name = "Juan Dela Cruz", Status = "Present", Time = "8:01 AM" },
        new Attendance { Name = "Maria Santos", Status = "Late", Time = "8:15 AM" }
    };
    }

    @inject NavigationManager nav

    void HandleLogout()
    {
        nav.NavigateTo("/login", true);
    }
}
    