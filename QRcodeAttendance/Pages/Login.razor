@page "/"
@page "/login"
@inject NavigationManager nav
@inject HttpClient http
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@using MudBlazor
@using System.Net.Http.Json
@using QRcodeAttendance

<div class="auth-page @(isLeaving ? "success-leave" : "")">

    <div class="login-shell">

        <div class="login-brand-panel">
            <div class="brand-badge">Teacher Portal</div>

            <h1 class="brand-title">QR Classroom Attendance</h1>

            <p class="brand-subtitle">
                A web-based attendance management portal for teachers with secure login,
                QR-based session handling, and real-time classroom monitoring.
            </p>

            <div class="brand-card-grid">
                <div class="brand-mini-card">
                    <div class="mini-card-title">Secure Access</div>
                    <div class="mini-card-text">Teacher accounts are managed by the system administrator.</div>
                </div>

                <div class="brand-mini-card">
                    <div class="mini-card-title">Fast Workflow</div>
                    <div class="mini-card-text">Generate QR sessions and monitor attendance in one place.</div>
                </div>

                <div class="brand-mini-card">
                    <div class="mini-card-title">Organized Records</div>
                    <div class="mini-card-text">Track sections, sessions, and attendance logs efficiently.</div>
                </div>
            </div>

        </div>

        <div class="login-form-panel">
            <div class="form-card">
                <div class="form-header">
                    <div class="form-title">Sign in</div>
                    <div class="form-subtitle">Use your teacher account credentials to continue.</div>
                </div>

                <MudForm @ref="form" Immediate="true">
                    <div class="form-group">

                        <MudTextField T="string"
                                      Placeholder="Email"
                                      @bind-Value="email"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Required="true"
                                      RequiredError="Email is required"
                                      Validation="@(new Func<string, string>(ValidateEmail))"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person" />

                        <MudTextField T="string"
                                      Placeholder="Password"
                                      @bind-Value="password"
                                      Variant="Variant.Outlined"
                                      InputType="@(showPassword ? InputType.Text : InputType.Password)"
                                      FullWidth="true"
                                      Required="true"
                                      RequiredError="Password is required"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Lock"
                                      AdornmentEnd="Adornment.End"
                                      AdornmentIconEnd="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                      OnAdornmentEndClick="@(() => showPassword = !showPassword)" />

                    </div>
                </MudForm>

                <div class="btn-group">
                    <MudButton OnClick="HandleLogin"
                               Variant="Variant.Filled"
                               FullWidth="true"
                               Disabled="@(isLoading || isLeaving)"
                               Class="login-btn">
                        @(isLoading ? "SIGNING IN..." : "SIGN IN")
                    </MudButton>
                </div>

                <div class="form-footer">
                    <div class="footer-note">Teacher accounts are created and maintained by the administrator.</div>
                    <div class="footer-version">QR Attendance System • Web Teacher Access</div>
                </div>
            </div>
        </div>

    </div>

</div>

@code {
    private bool showPassword = false;
    private bool isLoading = false;
    private bool isLeaving = false;

    private MudForm form;
    private string email;
    private string password;

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomCenter;
        Snackbar.Configuration.PreventDuplicates = true;
        Snackbar.Configuration.NewestOnTop = true;
        Snackbar.Configuration.ShowCloseIcon = true;
        Snackbar.Configuration.VisibleStateDuration = 2800;
        Snackbar.Configuration.HideTransitionDuration = 180;
        Snackbar.Configuration.ShowTransitionDuration = 180;

        var existingToken = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (!string.IsNullOrWhiteSpace(existingToken))
            nav.NavigateTo("/main_dashboard");
    }

    private string ValidateEmail(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "Email is required";

        try
        {
            var _ = new System.Net.Mail.MailAddress(value.Trim());
            return null;
        }
        catch
        {
            return "Enter a valid email address";
        }
    }

    private async Task HandleLogin()
    {
        await form.Validate();

        if (!form.IsValid)
        {
            Snackbar.Add("Please fix the form errors first.", Severity.Warning);
            return;
        }

        isLoading = true;
        StateHasChanged();

        var cleanEmail = email?.Trim();

        var data = new
        {
            email = cleanEmail,
            password = password
        };

        try
        {
            var response = await http.PostAsJsonAsync($"{ApiConfig.BaseUrl}/api/Auth/login", data);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (result != null && !string.IsNullOrWhiteSpace(result.token))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "token", result.token);
                    await JS.InvokeVoidAsync("localStorage.setItem", "userEmail", cleanEmail ?? "");

                    Snackbar.Add(
                        string.IsNullOrWhiteSpace(result.message) ? "Login successful!" : result.message,
                        Severity.Success
                    );

                    isLoading = false;
                    isLeaving = true;
                    StateHasChanged();

                    await Task.Delay(350);
                    nav.NavigateTo("/main_dashboard");
                }
                else
                {
                    Snackbar.Add("Login succeeded but no token was returned.", Severity.Error);
                    isLoading = false;
                }
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();

                Snackbar.Add(
                    string.IsNullOrWhiteSpace(errorText) ? "Invalid email or password." : errorText,
                    Severity.Error
                );

                isLoading = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cannot connect to backend: {ex.Message}", Severity.Error);
            isLoading = false;
        }
    }

    public class LoginResponse
    {
        public string token { get; set; }
        public string message { get; set; }
    }
}