@page "/"
@page "/login"
@inject NavigationManager nav
@using MudBlazor


<div class="main-container">

    <div class="login-box">

        
        <div class="left-side">
            <h1>
                QR Classroom <br />
                Attendance
            </h1>
            <img src="aclc.png" class="logo-img" />
        </div>


        <div class="right-side">

            <h1>LOGIN TO CONTINUE</h1>

            <div class="form-group">

                <MudTextField T="string"
                              Placeholder="Username"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Class="input-field" />

                <MudTextField T="string"
                              Placeholder="Password"
                              Variant="Variant.Outlined"
                              InputType="@(showPassword ? InputType.Text : InputType.Password)"
                              FullWidth="true"
                              Class="input-field"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => showPassword = !showPassword)" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="login-btn">
                    LOGIN
                </MudButton>

                <MudButton OnClick="@(() => nav.NavigateTo("/register"))"
                           Variant="Variant.Outlined"
                           FullWidth="true"
                           Class="register-btn">
                    CREATE ACCOUNT
                </MudButton>

            </div>

        </div>

    </div>

</div>
@code {
    bool showPassword = false;
}