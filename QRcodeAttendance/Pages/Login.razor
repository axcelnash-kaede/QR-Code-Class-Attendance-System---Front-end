@page "/"
@page "/login"
@inject NavigationManager nav
@using MudBlazor


<div class="main-container">

    <div class="login-box">

        
        <div class="left-side">
            <h1>
                QR Classroom <br />
                Attendance
            </h1>
            <img src="aclc.png" class="logo-img" />
        </div>


        <div class="right-side">

            <h1>LOGIN TO CONTINUE</h1>

            <MudForm @ref="form" Immediate="true">

                <div class="form-group">

                    <MudTextField T="string"
                                  Placeholder="Username"
                                  @bind-Value="username"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Required="true"
                                  RequiredError="Username is required" />

                    <MudTextField T="string"
                                  Placeholder="Password"
                                  @bind-Value="password"
                                  Variant="Variant.Outlined"
                                  InputType="@(showPassword ? InputType.Text : InputType.Password)"
                                  FullWidth="true"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => showPassword = !showPassword)" />

                </div>

            </MudForm>

            @if (!string.IsNullOrEmpty(message))
            {
                <p class="@messageClass">@message</p>
            }

            <div class="btn-group">

                <MudButton OnClick="HandleLogin"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Class="login-btn">
                    LOGIN
                </MudButton>

                <MudButton OnClick="@(() => nav.NavigateTo("/register"))"
                           Variant="Variant.Outlined"
                           FullWidth="true"
                           Class="register-btn">
                    CREATE ACCOUNT
                </MudButton>

            </div>

        </div>

    </div>

</div>
@code {
    bool showPassword = false;
    MudForm form;
    string username;
    string password;
    string message;
    string messageClass;

    private async Task HandleLogin()
    {
        await form.Validate();

        if (!form.IsValid)
        {
            message = "Please fix the errors above";
            messageClass = "error-msg";
            return;
        }

        // Simulated login (replace with API later)
        if (username != "admin" || password != "admin123")
        {
            message = "Invalid username or password";
            messageClass = "error-msg";
            return;
        }

        message = "Login successful!";
        messageClass = "success-msg";

        await Task.Delay(1000);
        nav.NavigateTo("/dashboard");
    }
}